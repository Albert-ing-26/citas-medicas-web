<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Crear cuenta - Citas Medicas</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="login-box registro-box">
    <h1>Crear cuenta de paciente</h1>
    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <form action="/registro" method="POST">
      <label for="nombre">Nombre</label>
      <input type="text" id="nombre" name="nombre" required value="<%= datos.nombre || '' %>">

      <label for="apellidos">Apellidos</label>
      <input type="text" id="apellidos" name="apellidos" required value="<%= datos.apellidos || '' %>">

      <label for="correo">Correo</label>
      <input type="email" id="correo" name="correo" required value="<%= datos.correo || '' %>">

      <label for="dni">DNI</label>
      <input type="text" id="dni" name="dni" required value="<%= datos.dni || '' %>">

      <label for="telefono">Telefono</label>
      <input type="text" id="telefono" name="telefono" value="<%= datos.telefono || '' %>">

      <label for="fecha_nacimiento">Fecha de nacimiento</label>
      <input type="date" id="fecha_nacimiento" name="fecha_nacimiento" value="<%= datos.fecha_nacimiento || '' %>">

      <label for="direccion">Direccion</label>
      <input type="text" id="direccion" name="direccion" value="<%= datos.direccion || '' %>">

      <label for="password">Contrasena</label>
      <input type="password" id="password" name="password" required>

      <button type="submit">Crear cuenta</button>
    </form>
    <p class="nota" style="text-align:center; margin-top:16px;">
      <a href="/login">Ya tengo cuenta, iniciar sesion</a>
    </p>
  </div>
</body>
</html>
