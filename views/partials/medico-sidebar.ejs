<aside class="admin-sidebar" style="background: linear-gradient(135deg, var(--admin-primary-dark) 0%, var(--admin-primary) 100%);">
  <div class="sidebar-brand">
    <!-- Clinical SVG Logo -->
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M19 10.5h-5.5V5c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v5.5H5c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5h5.5V19c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-5.5H19c.83 0 1.5-.67 1.5-1.5s-.67-1.5-1.5-1.5z"/>
    </svg>
    <span>MediMédico</span>
  </div>

  <div class="sidebar-nav">
    <a href="/medico" class="sidebar-link <%= activePage === 'inicio' ? 'active' : '' %>">
      <!-- Icon Dashboard/Home -->
      <svg viewBox="0 0 24 24">
        <rect x="3" y="3" width="7" height="9" rx="1"/>
        <rect x="14" y="3" width="7" height="5" rx="1"/>
        <rect x="14" y="12" width="7" height="9" rx="1"/>
        <rect x="3" y="16" width="7" height="5" rx="1"/>
      </svg>
      Inicio
    </a>
    
    <a href="/medico/agenda" class="sidebar-link <%= activePage === 'agenda' ? 'active' : '' %>">
      <!-- Icon Agenda -->
      <svg viewBox="0 0 24 24">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
        <path d="M9 16l2 2 4-4"/>
      </svg>
      Mi Agenda
    </a>

    <a href="/medico/dias-bloqueados" class="sidebar-link <%= activePage === 'bloqueos' ? 'active' : '' %>">
      <!-- Icon Calendar Block -->
      <svg viewBox="0 0 24 24">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
        <line x1="9" y1="14" x2="15" y2="14"/>
        <line x1="9" y1="18" x2="15" y2="18"/>
      </svg>
      Solicitudes de Bloqueo
    </a>
  </div>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="sidebar-user-avatar" title="<%= usuario.nombre %>" style="background: linear-gradient(135deg, var(--admin-accent), var(--admin-accent-dark));">
        <%= usuario.nombre.charAt(0).toUpperCase() %>
      </div>
      <div class="sidebar-user-info">
        <span class="sidebar-user-name">Dr(a). <%= usuario.nombre %></span>
        <span class="sidebar-user-role">Médico Activo</span>
      </div>
    </div>
  </div>
</aside>
