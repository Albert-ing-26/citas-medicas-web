    </svg>
  </button>
</div>

<script>
(function () {
  if (window.__jaxChatbotInitialized) return;
  window.__jaxChatbotInitialized = true;

  const contextMap = {
    login: {
      welcome: '¡Hola, soy Jax! Ingresa tus credenciales aquí para acceder de forma segura a tu cuenta médica.',
      quickActions: ['Ingresar', 'Registrarme', 'Ayuda rápida']
    },
    paciente: {
      welcome: '¡Hola! Bienvenido a tu portal. Aquí puedes agendar tus citas o revisar las que ya tienes programadas.',
      quickActions: ['Reservar cita', 'Ver historial', 'Cancelar cita']
    },
    medico: {
      welcome: '¡Hola! Estoy aquí para ayudarte a revisar tu agenda y administrar tus turnos.',
      quickActions: ['Ver agenda', 'Bloquear días', 'Confirmar citas']
    },
    admin: {
      welcome: '¡Hola! En este panel puedes ver el resumen gráfico del estado de las citas, médicos y reportes de hoy.',
      quickActions: ['Gestionar médicos', 'Ver solicitudes', 'Reportes']
    }
  };

  function getContext() {
    const path = window.location.pathname || '/';
    if (path === '/' || path === '/login' || path === '/registro') return contextMap.login;
    if (path.startsWith('/paciente/dashboard')) return { ...contextMap.paciente, welcome: '¡Hola! Bienvenido a tu portal. Aquí puedes agendar tus citas o revisar las que ya tienes programadas.' };
    if (path.startsWith('/paciente/reservar')) return { ...contextMap.paciente, welcome: '¡Hola! Selecciona la especialidad que necesitas, elige a tu doctor y programa tu cita en segundos.' };
    if (path.startsWith('/paciente')) return contextMap.paciente;
    if (path.startsWith('/medico')) return contextMap.medico;
    if (path.startsWith('/admin/especialidades')) return { ...contextMap.admin, welcome: '¡Hola! Aquí puedes ver la lista de especialidades de la clínica, editarlas o añadir nuevas de forma rápida.' };
    if (path.startsWith('/admin/medicos')) return { ...contextMap.admin, welcome: '¡Hola! Este es el registro del personal médico. Aquí puedes gestionar sus horarios, especialidades y datos de contacto.' };
    if (path.startsWith('/admin')) return { ...contextMap.admin, welcome: '¡Hola! En este panel puedes ver el resumen gráfico del estado de las citas, médicos y reportes de hoy.' };
    return contextMap.login;
  }

  function getOverlayMessage() {
    const path = window.location.pathname || '/';
    if (path === '/login' || path === '/registro') return '¡Hola, soy Jax! Ingresa tus credenciales aquí para acceder de forma segura a tu cuenta médica.';
    if (path.startsWith('/admin/dashboard')) return '¡Hola! En este panel puedes ver el resumen gráfico del estado de las citas, médicos y reportes de hoy.';
    if (path.startsWith('/admin/especialidades')) return '¡Hola! Aquí puedes ver la lista de especialidades de la clínica, editarlas o añadir nuevas de forma rápida.';
    if (path.startsWith('/admin/medicos')) return '¡Hola! Este es el registro del personal médico. Aquí puedes gestionar sus horarios, especialidades y datos de contacto.';
    if (path.startsWith('/paciente/dashboard')) return '¡Hola! Bienvenido a tu portal. Aquí puedes agendar tus citas o revisar las que ya tienes programadas.';
    if (path.startsWith('/paciente/reservar')) return '¡Hola! Selecciona la especialidad que necesitas, elige a tu doctor y programa tu cita en segundos.';
    if (path.startsWith('/admin')) return '¡Hola! Desde este panel puedes administrar la operación de la clínica con rapidez.';
    if (path.startsWith('/paciente')) return '¡Hola! Aquí puedes trabajar tus citas y trámites del paciente.';
    return '¡Hola! Estoy aquí para ayudarte a moverte por la plataforma con tranquilidad.';
  }

  function createBubble(text, type) {
    const bubble = document.createElement('div');
    bubble.className = `chat-bubble chat-bubble-${type}`;
    bubble.textContent = text;
    return bubble;
  }

  function renderQuickActions(actions) {
    const actionsBox = document.getElementById('chatbox-actions');
    if (!actionsBox) return;
    actionsBox.innerHTML = '';
    actions.forEach((action) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'chat-action';
      button.textContent = action;
      button.onclick = function (event) {
        event.stopPropagation();
        handleQuickReply(action);
      };
      actionsBox.appendChild(button);
    });
  }

  function appendMessage(text, type) {
    const messages = document.getElementById('chatbox-messages');
    if (!messages) return;
    const bubble = createBubble(text, type);
    messages.appendChild(bubble);
    messages.scrollTop = messages.scrollHeight;
  }

  function getReply(action) {
    const context = getContext();
    const lower = action.toLowerCase();
    if (lower.includes('registr')) return 'Puedes registrarte desde la opción de registro y luego reservar tus citas desde el panel de paciente.';
    if (lower.includes('reserv')) return 'Dirígete a la sección Reservar cita y elige especialidad, médico, fecha y horario disponible.';
    if (lower.includes('historial') || lower.includes('cita')) return 'En tu panel puedes revisar tus citas activas y el estado de cada una en un solo lugar.';
    if (lower.includes('agenda')) return 'Tu agenda te permite ver turnos, confirmar pacientes y mantener el día organizado.';
    if (lower.includes('bloque')) return 'Desde solicitudes de bloqueo puedes indicar los días en los que no atenderás.';
    if (lower.includes('solicitud')) return 'Las solicitudes pendientes aparecen en el panel de administración para revisión rápida.';
    if (lower.includes('reporte')) return 'Los reportes te ayudan a revisar la actividad general por estado, especialidad y médico.';
    if (lower.includes('médico') || lower.includes('medico')) return 'Puedes gestionar médicos desde la sección dedicada y asignarles especialidades.';
    return context.welcome;
  }

  function handleQuickReply(action) {
    appendMessage(action, 'user');
    const reply = getReply(action);
    setTimeout(() => appendMessage(reply, 'bot'), 250);
    setTimeout(() => renderQuickActions(getContext().quickActions), 320);
  }

  function showFloatingButton() {
    const button = document.getElementById('jax-floating-button');
    if (button) {
      button.classList.add('is-visible');
    }
  }

  function dismissWelcome() {
    const overlay = document.getElementById('jax-welcome-overlay');
    if (!overlay) return;
    overlay.classList.add('is-hidden');
    setTimeout(() => {
      overlay.style.display = 'none';
      showFloatingButton();
    }, 400);
  }

  window.sendUserMessage = function () {
    const input = document.getElementById('chatbox-input');
    const value = input ? input.value.trim() : '';
    if (!value) return;
    appendMessage(value, 'user');
    input.value = '';
    const reply = value.toLowerCase().includes('ayuda')
      ? 'Puedo ayudarte con acceso, reservas, agenda o reportes. Elige una opción rápida o escribe tu consulta.'
      : 'Gracias por tu mensaje. Estoy aquí para orientarte paso a paso dentro de la plataforma.';
    setTimeout(() => appendMessage(reply, 'bot'), 220);
    setTimeout(() => renderQuickActions(getContext().quickActions), 320);
  };

  window.toggleChat = function () {
    const chatbox = document.getElementById('chatbox-window');
    const button = document.getElementById('jax-floating-button');
    if (!chatbox) return;
    const willOpen = !chatbox.classList.contains('is-open');
    chatbox.classList.toggle('is-open', willOpen);
    if (button) button.classList.toggle('is-active', willOpen);
    if (willOpen) {
      const input = document.getElementById('chatbox-input');
      setTimeout(() => input && input.focus(), 180);
    }
  };

  window.closeChat = function () {
    const chatbox = document.getElementById('chatbox-window');
    const button = document.getElementById('jax-floating-button');
    if (chatbox) chatbox.classList.remove('is-open');
    if (button) button.classList.remove('is-active');
  };

  function init() {
    const chatbox = document.getElementById('chatbox-window');
    const messages = document.getElementById('chatbox-messages');
    const overlay = document.getElementById('jax-welcome-overlay');
    const button = document.getElementById('jax-floating-button');
    if (!chatbox || !messages || !overlay || !button) return;

    const context = getContext();
    const overlayMessage = document.getElementById('jax-overlay-message');
    if (overlayMessage) overlayMessage.textContent = getOverlayMessage();
    renderQuickActions(context.quickActions);
    appendMessage(context.welcome, 'bot');

    overlay.addEventListener('click', dismissWelcome);
    button.addEventListener('click', function (event) {
      event.stopPropagation();
      toggleChat();
    });

    document.addEventListener('click', function (event) {
      const shell = document.getElementById('chatbot-shell');
      if (shell && !shell.contains(event.target)) {
        closeChat();
      }
    });
  }

  document.addEventListener('DOMContentLoaded', init);
})();
</script>
