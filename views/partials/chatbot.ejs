<style>
  .typing-indicator {
    display: flex !important;
    align-items: center;
    gap: 4px;
    width: auto;
    max-width: 60px;
    padding: 10px 15px;
    justify-content: center;
  }
  .typing-indicator span {
    width: 6px;
    height: 6px;
    background-color: #0f766e;
    border-radius: 50%;
    display: inline-block;
    animation: typing-bounce 1.4s infinite ease-in-out both;
  }
  .typing-indicator span:nth-child(1) {
    animation-delay: -0.32s;
  }
  .typing-indicator span:nth-child(2) {
    animation-delay: -0.16s;
  }
  @keyframes typing-bounce {
    0%, 80%, 100% { 
      transform: scale(0);
    } 40% { 
      transform: scale(1.0);
    }
  }
</style>
<div class="chatbot-shell" id="chatbot-shell">
  <div class="chatbox-window" id="chatbox-window" aria-live="polite">
    <div class="chatbox-header">
      <div>
        <strong>Jax</strong>
        <span>Doctor guía</span>
      </div>
      <button class="chatbox-close" type="button" onclick="event.stopPropagation(); closeChat();">×</button>
    </div>

    <div class="chatbox-messages" id="chatbox-messages"></div>

    <div class="chatbox-actions" id="chatbox-actions"></div>

    <form class="chatbox-form" onsubmit="event.preventDefault(); sendUserMessage();">
      <input id="chatbox-input" type="text" autocomplete="off" placeholder="Escribe tu duda aquí..." />
      <button type="submit">Enviar</button>
    </form>
  </div>

  <div class="jax-assistant-shell" id="jax-assistant-shell">
    <div class="jax-thought-bubble" id="jax-thought-bubble" role="status" aria-live="polite" aria-hidden="true">
      <p id="jax-bubble-message"></p>
    </div>
    <button class="jax-floating-button" id="jax-floating-button" type="button" aria-label="Abrir asistente virtual">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" class="doctor-jax-svg jax-doctor-svg-small" role="img" aria-hidden="true">
        <circle cx="100" cy="100" r="95" fill="#f0fdfa" stroke="#0d6b6b" stroke-width="3" />
        <path d="M85 110 L115 110 L110 130 L90 130 Z" fill="#e0a890" />
        <path d="M75 130 L125 130 L135 185 L65 185 Z" fill="#20b2aa" />
        <path d="M100 130 L85 155 L115 155 Z" fill="#117a7a" />
        <path d="M96 150 L104 150 L107 175 L100 185 L93 175 Z" fill="#0d3c3c" />
        <path d="M60 185 L140 185 L145 200 L55 200 Z" fill="#ffffff" />
        <path d="M70 130 L100 170 L100 185 L55 185 L65 145 Z" fill="#ffffff" stroke="#e2e8f0" stroke-width="1.5" />
        <path d="M130 130 L100 170 L100 185 L145 185 L135 145 Z" fill="#ffffff" stroke="#e2e8f0" stroke-width="1.5" />
        <path d="M70 130 L82 155 L75 155 Z" fill="#f8fafc" />
        <path d="M130 130 L118 155 L125 155 Z" fill="#f8fafc" />
        <path d="M78 120 C 78 145, 122 145, 122 120" fill="none" stroke="#1e293b" stroke-width="5" stroke-linecap="round" />
        <path d="M115 142 L115 160" fill="none" stroke="#1e293b" stroke-width="4" />
        <circle cx="115" cy="163" r="8" fill="#94a3b8" stroke="#1e293b" stroke-width="3" />
        <circle cx="115" cy="163" r="3" fill="#edf2f7" />
        <path d="M75 75 C75 50, 125 50, 125 75 C125 105, 75 105, 75 75 Z" fill="#ffd5c3" />
        <circle cx="72" cy="78" r="7" fill="#ffd5c3" />
        <circle cx="128" cy="78" r="7" fill="#ffd5c3" />
        <circle cx="90" cy="74" r="4" fill="#1e293b" />
        <circle cx="110" cy="74" r="4" fill="#1e293b" />
        <circle cx="91" cy="72" r="1.5" fill="#ffffff" />
        <circle cx="111" cy="72" r="1.5" fill="#ffffff" />
        <path d="M83 67 C86 65, 94 65, 97 67" fill="none" stroke="#1e293b" stroke-width="2" stroke-linecap="round" />
        <path d="M103 67 C106 65, 114 65, 117 67" fill="none" stroke="#1e293b" stroke-width="2" stroke-linecap="round" />
        <path d="M98 76 Q100 81 102 76" fill="none" stroke="#e0a890" stroke-width="2" stroke-linecap="round" />
        <path d="M88 84 Q100 96 112 84" fill="none" stroke="#e07a5f" stroke-width="3.5" stroke-linecap="round" />
        <path d="M73 72 C71 58, 80 44, 100 44 C120 44, 129 58, 127 72 C124 67, 120 62, 115 62 C105 62, 103 52, 95 52 C85 52, 80 64, 73 72 Z" fill="#1e293b" />
        <circle cx="90" cy="74" r="12" fill="none" stroke="#0f172a" stroke-width="2.5" />
        <circle cx="110" cy="74" r="12" fill="none" stroke="#0f172a" stroke-width="2.5" />
        <path d="M102 74 L98 74" fill="none" stroke="#0f172a" stroke-width="2.5" />
      </svg>
    </button>
  </div>
</div>

<script>
(function () {
  if (window.__jaxChatbotInitialized) return;
  window.__jaxChatbotInitialized = true;

  // Datos del usuario inyectados desde la sesión en el servidor (EJS)
  const JAX_USER = {
    nombre: '<%= typeof usuario !== "undefined" && usuario && usuario.nombre ? usuario.nombre.split(" ")[0] : "" %>',
    rol:    '<%= typeof usuario !== "undefined" && usuario && usuario.rol    ? usuario.rol    : "" %>'
  };

  // Genera el saludo inicial estático (sin llamar a la API)
  function generarSaludoInicial() {
    const nombre = JAX_USER.nombre;
    const rol    = JAX_USER.rol;
    let titulo = '';
    if (rol === 'admin')   titulo = 'Administrador';
    else if (rol === 'medico') titulo = 'Doctor';
    else if (nombre)       titulo = 'Paciente';

    if (titulo && nombre) {
      return `Hola, soy tu asistente virtual Jax, ¿en qué te puedo ayudar, ${titulo} ${nombre}?`;
    }
    return '¡Hola! Soy Jax, tu asistente virtual. ¿En qué puedo ayudarte hoy?';
  }

  // Acciones rápidas según el rol
  function getQuickActions() {
    const rol = JAX_USER.rol;
    if (rol === 'admin')  return ['Gestionar médicos', 'Ver solicitudes', 'Reportes'];
    if (rol === 'medico') return ['Ver agenda', 'Bloquear días', 'Confirmar citas'];
    return ['Reservar cita', 'Ver historial', 'Cancelar cita'];
  }

  // Contexto para compatibilidad (solo se usa en acciones rápidas ahora)
  function getContext() {
    return { quickActions: getQuickActions() };
  }

  const bubbleMessageMap = {
    default: { message: '¡Hola! Soy Jax, tu asistente virtual. ¿En qué puedo ayudarte?', duration: 5000 }
  };

  function getBubbleConfig() {
    return bubbleMessageMap.default;
  }

  function resetBubbleState() {
    const bubble = document.getElementById('jax-thought-bubble');
    if (!bubble) return;
    bubble.classList.remove('is-visible', 'is-hidden');
    bubble.classList.add('is-hidden');
    bubble.setAttribute('aria-hidden', 'true');
  }

  function hideBubble() {
    const bubble = document.getElementById('jax-thought-bubble');
    if (!bubble) return;
    bubble.classList.remove('is-visible');
    bubble.classList.add('is-hidden');
    bubble.setAttribute('aria-hidden', 'true');
  }

  function showBubble() {
    const bubble = document.getElementById('jax-thought-bubble');
    const messageNode = document.getElementById('jax-bubble-message');
    if (!bubble || !messageNode) return;

    if (window.jaxTimeoutId) {
      clearTimeout(window.jaxTimeoutId);
    }

    resetBubbleState();
    const config = getBubbleConfig();
    messageNode.textContent = config.message;

    requestAnimationFrame(() => {
      bubble.classList.remove('is-hidden');
      bubble.classList.add('is-visible');
      bubble.setAttribute('aria-hidden', 'false');
    });

    window.jaxTimeoutId = window.setTimeout(() => {
      hideBubble();
    }, config.duration);
  }

  function createBubble(text, type) {
    const bubble = document.createElement('div');
    bubble.className = `chat-bubble chat-bubble-${type}`;
    bubble.textContent = text;
    return bubble;
  }

  function renderQuickActions(actions) {
    const actionsBox = document.getElementById('chatbox-actions');
    if (!actionsBox) return;
    actionsBox.innerHTML = '';
    actions.forEach((action) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'chat-action';
      button.textContent = action;
      button.onclick = function (event) {
        event.stopPropagation();
        handleQuickReply(action);
      };
      actionsBox.appendChild(button);
    });
  }

  function appendMessage(text, type) {
    const messages = document.getElementById('chatbox-messages');
    if (!messages) return;
    const bubble = createBubble(text, type);
    messages.appendChild(bubble);
    messages.scrollTop = messages.scrollHeight;
  }

  function showTypingIndicator() {
    const messages = document.getElementById('chatbox-messages');
    if (!messages) return null;
    const bubble = document.createElement('div');
    bubble.className = 'chat-bubble chat-bubble-bot typing-indicator';
    bubble.innerHTML = '<span></span><span></span><span></span>';
    messages.appendChild(bubble);
    messages.scrollTop = messages.scrollHeight;
    return bubble;
  }

  async function fetchGeminiReply(userMessage) {
    const typingIndicator = showTypingIndicator();

    // Inferir el rol del usuario según la ruta actual
    function getUserRole() {
      const path = window.location.pathname || '/';
      if (path.startsWith('/admin')) return 'admin';
      if (path.startsWith('/medico')) return 'medico';
      return 'paciente';
    }
    const userRole = getUserRole();
    const userName = JAX_USER.nombre || '';
    
    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ message: userMessage, role: userRole, userName: userName })
      });
      
      if (typingIndicator) {
        typingIndicator.remove();
      }
      
      let data = null;
      try {
        data = await response.json();
      } catch (jsonErr) {
        console.error('Error parsing response JSON:', jsonErr);
      }

      if (!response.ok) {
        const errorMessage = (data && (data.error || data.reply)) ? (data.error || data.reply) : 'Lo siento, he experimentado una dificultad para responder en este momento. Por favor, intenta de nuevo.';
        appendMessage(errorMessage, 'bot');
      } else {
        if (data && (data.response || data.reply)) {
          appendMessage(data.response || data.reply, 'bot');
        } else if (data && data.error) {
          appendMessage(data.error, 'bot');
        } else {
          appendMessage('Lo siento, no he podido obtener una respuesta válida.', 'bot');
        }
      }
    } catch (error) {
      console.error('Error fetching chat response:', error);
      if (typingIndicator) {
        typingIndicator.remove();
      }
      appendMessage('Lo siento, en este momento no puedo conectarme con el servicio de Jax. Por favor, intenta de nuevo más tarde.', 'bot');
    }
    
    // Volver a renderizar las acciones rápidas correspondientes al contexto
    renderQuickActions(getContext().quickActions);
  }

  function handleQuickReply(action) {
    appendMessage(action, 'user');
    // Limpiar las acciones rápidas mientras se responde
    const actionsBox = document.getElementById('chatbox-actions');
    if (actionsBox) actionsBox.innerHTML = '';
    
    fetchGeminiReply(action);
  }

  window.sendUserMessage = function () {
    const input = document.getElementById('chatbox-input');
    const value = input ? input.value.trim() : '';
    if (!value) return;
    appendMessage(value, 'user');
    input.value = '';
    
    // Limpiar las acciones rápidas mientras se responde
    const actionsBox = document.getElementById('chatbox-actions');
    if (actionsBox) actionsBox.innerHTML = '';
    
    fetchGeminiReply(value);
  };

  window.toggleChat = function () {
    const chatbox = document.getElementById('chatbox-window');
    const button = document.getElementById('jax-floating-button');
    if (!chatbox) return;
    const willOpen = !chatbox.classList.contains('is-open');
    chatbox.classList.toggle('is-open', willOpen);
    if (button) button.classList.toggle('is-active', willOpen);
    if (willOpen) {
      const input = document.getElementById('chatbox-input');
      setTimeout(() => input && input.focus(), 180);
    }
  };

  window.closeChat = function () {
    const chatbox = document.getElementById('chatbox-window');
    const button = document.getElementById('jax-floating-button');
    if (chatbox) chatbox.classList.remove('is-open');
    if (button) button.classList.remove('is-active');
  };

  function init() {
    const chatbox = document.getElementById('chatbox-window');
    const messages = document.getElementById('chatbox-messages');
    const button = document.getElementById('jax-floating-button');
    if (!chatbox || !messages || !button) return;

    // Saludo inicial estático basado en rol/nombre del usuario — SIN llamar a la API
    renderQuickActions(getQuickActions());
    appendMessage(generarSaludoInicial(), 'bot');

    // Burbuja de pensamiento simplificada: siempre el saludo inicial
    const bubble = document.getElementById('jax-thought-bubble');
    const messageNode = document.getElementById('jax-bubble-message');
    if (bubble && messageNode) {
      messageNode.textContent = generarSaludoInicial();
      requestAnimationFrame(() => {
        bubble.classList.remove('is-hidden');
        bubble.classList.add('is-visible');
        bubble.setAttribute('aria-hidden', 'false');
      });
      window.jaxTimeoutId = setTimeout(() => {
        bubble.classList.remove('is-visible');
        bubble.classList.add('is-hidden');
        bubble.setAttribute('aria-hidden', 'true');
      }, 6000);
    }

    button.addEventListener('click', function (event) {
      event.stopPropagation();
      if (bubble) {
        bubble.classList.remove('is-visible');
        bubble.classList.add('is-hidden');
        bubble.setAttribute('aria-hidden', 'true');
      }
      toggleChat();
    });

    document.addEventListener('click', function (event) {
      const shell = document.getElementById('chatbot-shell');
      if (shell && !shell.contains(event.target)) {
        closeChat();
      }
    });
  }

  document.addEventListener('DOMContentLoaded', init);
})();
</script>
