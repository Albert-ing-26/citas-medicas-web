<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Médico - Citas Médicas</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-container">
    <!-- Sidebar Navigation -->
    <%- include('../partials/medico-sidebar', { activePage: 'inicio' }) %>

    <div class="admin-main">
      <!-- Top Header -->
      <%- include('../partials/medico-header', { title: 'Panel del Médico' }) %>

      <div class="admin-content">
        <!-- Hero Section -->
        <section class="glass-card" style="margin-bottom: 32px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
          <div>
            <div style="font-size: 13px; font-weight: 600; text-transform: uppercase; color: var(--admin-primary); letter-spacing: 0.05em; margin-bottom: 8px;">Panel del médico</div>
            <h2 style="font-family: var(--font-display); font-size: 24px; font-weight: 700; margin: 0 0 10px 0;">Organiza tu agenda con mayor claridad</h2>
            <p style="color: var(--admin-muted); font-size: 14px; margin: 0; max-width: 700px;">Revisa tus citas del día, confirma la asistencia de los pacientes y gestiona los días en los que no atenderás desde un tablero visual.</p>
          </div>
          <div style="background: var(--admin-primary-light); color: var(--admin-primary-dark); font-weight: 600; font-size: 12px; padding: 8px 16px; border-radius: 99px; border: 1px solid rgba(13, 115, 119, 0.1);">
            Consultorio Activo
          </div>
        </section>

        <!-- Stats Grid -->
        <div class="admin-stats-grid">
          <!-- Appointments Today -->
          <div class="stat-card">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <div class="stat-details">
              <div class="stat-number"><%= citasHoy %></div>
              <div class="stat-label">Citas Hoy</div>
            </div>
          </div>

          <!-- Appointments Pending -->
          <div class="stat-card <%= citasPendientes > 0 ? 'accent' : '' %>">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="stat-details">
              <div class="stat-number"><%= citasPendientes %></div>
              <div class="stat-label">Por Confirmar</div>
            </div>
          </div>

          <!-- Days Blocked -->
          <div class="stat-card">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </div>
            <div class="stat-details">
              <div class="stat-number"><%= diasBloqueados %></div>
              <div class="stat-label">Días Bloqueados</div>
            </div>
          </div>

          <!-- Pending Block Requests -->
          <div class="stat-card">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
              </svg>
            </div>
            <div class="stat-details">
              <div class="stat-number"><%= solicitudesPendientes %></div>
              <div class="stat-label">Solicitudes de Bloqueo</div>
            </div>
          </div>
        </div>

        <!-- Content Grid (Actions + Chart) -->
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; align-items: start;" class="dashboard-main-grid">
          <div>
            <h3 style="margin-top: 0; margin-bottom: 16px;">Accesos Rápidos</h3>
            
            <div class="admin-actions-grid" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));">
              <!-- Action Agenda -->
              <a href="/medico/agenda" class="action-card destacada">
                <div class="action-card-icon">
                  <svg viewBox="0 0 24 24">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                    <path d="M9 16l2 2 4-4"/>
                  </svg>
                </div>
                <h4 class="action-card-title">Ver mi agenda</h4>
                <p class="action-card-desc">Consulta tus citas del día, confírmalas, regístralas como atendidas o cancélalas.</p>
                <div class="action-card-arrow">Ver mi agenda <span>&rarr;</span></div>
              </a>

              <!-- Action Request Block -->
              <a href="/medico/dias-bloqueados" class="action-card">
                <div class="action-card-icon">
                  <svg viewBox="0 0 24 24">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                    <line x1="9" y1="14" x2="15" y2="14"/>
                  </svg>
                </div>
                <h4 class="action-card-title">Solicitar bloqueo</h4>
                <p class="action-card-desc">Envía una solicitud al administrador para bloquear días específicos en los que no darás citas.</p>
                <div class="action-card-arrow">Gestionar bloqueo <span>&rarr;</span></div>
              </a>
            </div>
          </div>

          <!-- Chart Area -->
          <div>
            <h3 style="margin-top: 0; margin-bottom: 16px;">Vista de trabajo</h3>
            <div class="glass-card" style="padding: 24px;">
              <h4 style="margin: 0 0 8px 0; font-family: var(--font-body); font-size: 15px; font-weight: 600; color: var(--admin-ink);">Distribución Operativa</h4>
              <p style="color: var(--admin-muted); font-size: 12px; margin: 0 0 20px 0; line-height: 1.4;">Resumen proporcional de la carga de citas y bloqueos actuales.</p>
              <div style="position: relative; height: 260px; width: 100%;">
                <canvas id="medicoChart"></canvas>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const ctx = document.getElementById('medicoChart');
      if (!ctx) return;
      new Chart(ctx, {
        type: 'pie',
        data: {
          labels: ['Hoy', 'Por confirmar', 'Bloqueados'],
          datasets: [{
            data: [<%= citasHoy %>, <%= citasPendientes %>, <%= diasBloqueados %>],
            backgroundColor: ['#0d7377', '#ff6f59', '#1e9e63'],
            borderColor: '#ffffff',
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { 
            legend: { 
              position: 'bottom',
              labels: {
                font: { family: 'Inter', size: 12 }
              }
            } 
          }
        }
      });
    });
  </script>
</body>
</html>
