<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Solicitudes de bloqueo</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <h1>Bienvenido, Dr(a). <%= usuario.nombre %></h1>
  <nav>
    <a href="/medico">Inicio</a> |
    <a href="/medico/agenda">Mi agenda</a> |
    <a href="/medico/dias-bloqueados">Solicitudes de bloqueo</a>
  </nav>
  <%- include('../partials/perfil-widget') %>

  <div class="contenido">
    <h2>Solicitar bloqueo de dia</h2>
    <p class="nota">Al solicitar un dia, tu solicitud queda pendiente hasta que el administrador la apruebe. Los pacientes solo dejan de poder reservar contigo ese dia una vez aprobada. Si ya tenias citas agendadas antes de que se apruebe, esas citas NO se cancelan automaticamente: revisalas tu mismo en tu agenda.</p>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <% if (aviso) { %>
      <p class="nota" style="color:#b45309;"><%= aviso %></p>
    <% } %>

    <form class="formulario" method="POST" action="/medico/dias-bloqueados/nuevo">
      <label for="fecha">Fecha a solicitar</label>
      <input type="date" id="fecha" name="fecha" required min="<%= hoy %>">

      <label for="motivo">Motivo (opcional)</label>
      <input type="text" id="motivo" name="motivo" placeholder="Ej: vacaciones, capacitacion">

      <button type="submit">Solicitar bloqueo</button>
    </form>

    <table class="tabla" style="margin-top:24px;">
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Motivo</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% bloqueos.forEach(b => { %>
          <tr>
            <td><%= b.fecha.toISOString ? b.fecha.toISOString().substring(0,10) : b.fecha %></td>
            <td><%= b.motivo || '-' %></td>
            <td>
              <% if (b.estado === 'aprobado') { %>
                <span class="estado-activo">Aprobado</span>
              <% } else if (b.estado === 'pendiente') { %>
                <span style="color:#b45309;font-weight:500;">Pendiente</span>
              <% } else { %>
                <span class="estado-bloqueado">Rechazado</span>
              <% } %>
            </td>
            <td>
              <form action="/medico/dias-bloqueados/<%= b.id_bloqueo %>/eliminar" method="POST"
                    onsubmit="return confirm('<%= b.estado === 'pendiente' ? 'Retirar esta solicitud?' : 'Desbloquear este dia?' %>');">
                <button type="submit" class="link-eliminar">
                  <%= b.estado === 'pendiente' ? 'Retirar solicitud' : 'Desbloquear' %>
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (bloqueos.length === 0) { %>
          <tr><td colspan="4">No tienes ninguna solicitud de bloqueo.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>
