<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Solicitudes de Bloqueo - Panel Médico</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-container">
    <!-- Sidebar Navigation -->
    <%- include('../partials/medico-sidebar', { activePage: 'bloqueos' }) %>

    <div class="admin-main">
      <!-- Top Header -->
      <%- include('../partials/medico-header', { title: 'Solicitudes de Bloqueo de Días' }) %>

      <div class="admin-content">
        <!-- Explanatory Alert -->
        <div class="alert alert-info" style="margin-bottom: 28px; line-height: 1.5;">
          <strong>Información sobre bloqueos:</strong> Al solicitar un día, tu solicitud queda en estado pendiente hasta que el administrador la apruebe. Los pacientes dejarán de poder reservar contigo en ese día una vez aprobada.
          <br>
          <small style="margin-top: 4px; display: block; opacity: 0.9;">* Nota: Las citas que ya tenías agendadas antes del bloqueo <strong>no se cancelan automáticamente</strong>. Por favor, revísalas en tu agenda.</small>
        </div>

        <!-- Error/Notice Alerts -->
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <% if (aviso) { %>
          <div class="alert alert-info" style="background: #fffbeb; color: #b45309; border-color: #fde68a;"><%= aviso %></div>
        <% } %>

        <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 32px; align-items: start;" class="bloqueos-grid">
          <!-- Request Form Card -->
          <div class="glass-card" style="padding: 28px;">
            <h4 style="margin: 0 0 16px 0; font-family: var(--font-body); font-size: 15px; font-weight: 600; color: var(--admin-primary);">Nueva Solicitud</h4>
            
            <form class="admin-form" method="POST" action="/medico/dias-bloqueados/nuevo">
              <div class="form-group">
                <label for="fecha">Fecha a solicitar</label>
                <input type="date" id="fecha" name="fecha" class="form-control" required min="<%= hoy %>">
              </div>

              <div class="form-group">
                <label for="motivo">Motivo (opcional)</label>
                <input type="text" id="motivo" name="motivo" class="form-control" placeholder="Ej: vacaciones, capacitación">
              </div>

              <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 4px;">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                Solicitar Bloqueo
              </button>
            </form>
          </div>

          <!-- Requests Table -->
          <div class="table-container">
            <div class="table-header-bar">
              <h3>Tus Solicitudes de Bloqueo</h3>
              <span style="font-size: 12px; color: var(--admin-muted); font-weight: 500;"><%= bloqueos.length %> solicitudes</span>
            </div>

            <table class="admin-table">
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Motivo</th>
                  <th>Estado</th>
                  <th style="text-align: right;">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% bloqueos.forEach(b => { %>
                  <tr>
                    <td style="font-weight: 600; color: var(--admin-primary); font-family: var(--font-mono); font-size: 13px;">
                      <%= b.fecha.toISOString ? b.fecha.toISOString().substring(0,10) : b.fecha %>
                    </td>
                    <td>
                      <span style="font-style: italic; color: var(--admin-muted);"><%= b.motivo || '-' %></span>
                    </td>
                    <td>
                      <!-- Status Badge -->
                      <span class="status-badge <%= b.estado %>">
                        <%= b.estado %>
                      </span>
                    </td>
                    <td style="text-align: right;">
                      <form action="/medico/dias-bloqueados/<%= b.id_bloqueo %>/eliminar" method="POST"
                            onsubmit="return confirm('<%= b.estado === 'pendiente' ? '¿Deseas retirar esta solicitud?' : '¿Deseas desbloquear este día?' %>');"
                            style="display:inline;">
                        <button type="submit" class="table-action-btn eliminar" style="padding: 4px 10px;">
                          <%= b.estado === 'pendiente' ? 'Retirar' : 'Desbloquear' %>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
                <% if (bloqueos.length === 0) { %>
                  <tr>
                    <td colspan="4" style="text-align: center; color: var(--admin-muted); padding: 30px;">
                      No tienes ninguna solicitud de bloqueo registrada.
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
