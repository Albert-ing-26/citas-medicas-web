<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Especialidades - Panel Administrador</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-container">
    <!-- Sidebar Navigation -->
    <%- include('../../partials/admin-sidebar', { activePage: 'especialidades' }) %>

    <div class="admin-main">
      <!-- Top Header -->
      <%- include('../../partials/admin-header', { title: 'Catálogo de Especialidades' }) %>

      <div class="admin-content">
        <!-- Error Alert -->
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
          <p style="color: var(--admin-muted); font-size: 14px; margin: 0;">Administra las especialidades médicas disponibles y define la duración predeterminada de las citas.</p>
          <a class="btn btn-primary" href="/admin/especialidades/nueva">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 4px;">
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nueva Especialidad
          </a>
        </div>

        <!-- Specialties Table -->
        <div class="table-container">
          <div class="table-header-bar">
            <h3>Listado de Especialidades</h3>
            <span style="font-size: 12px; color: var(--admin-muted); font-weight: 500;"><%= especialidades.length %> especialidades en catálogo</span>
          </div>
          
          <table class="admin-table">
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Duración de Cita (min)</th>
                <th style="text-align: right;">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% especialidades.forEach(esp => { %>
                <tr>
                  <td style="font-weight: 600;"><%= esp.nombre %></td>
                  <td>
                    <span style="background: var(--admin-primary-light); color: var(--admin-primary-dark); font-weight: 600; font-size: 13px; padding: 4px 10px; border-radius: 6px;">
                      <%= esp.duracion_cita_minutos %> min
                    </span>
                  </td>
                  <td style="text-align: right;">
                    <a href="/admin/especialidades/<%= esp.id_especialidad %>/editar" class="table-action-btn">
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 2px;">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                      </svg>
                      Editar
                    </a>
                    
                    <form action="/admin/especialidades/<%= esp.id_especialidad %>/eliminar" method="POST"
                          style="display:inline"
                          onsubmit="return confirm('¿Seguro que deseas eliminar esta especialidad?');">
                      <button type="submit" class="table-action-btn eliminar">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 2px;">
                          <polyline points="3 6 5 6 21 6"/>
                          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                        </svg>
                        Eliminar
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
              <% if (especialidades.length === 0) { %>
                <tr>
                  <td colspan="3" style="text-align: center; color: var(--admin-muted); padding: 30px;">
                    No hay especialidades registradas todavía.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
