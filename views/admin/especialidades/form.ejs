<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= especialidad ? 'Editar' : 'Nueva' %> Especialidad - Panel Administrador</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-container">
    <!-- Sidebar Navigation -->
    <%- include('../../partials/admin-sidebar', { activePage: 'especialidades' }) %>

    <div class="admin-main">
      <!-- Top Header -->
      <%- include('../../partials/admin-header', { title: especialidad && especialidad.id_especialidad ? 'Editar Especialidad' : 'Nueva Especialidad' }) %>

      <div class="admin-content">
        <!-- Back Link -->
        <div style="margin-bottom: 24px;">
          <a href="/admin/especialidades" style="display: inline-flex; align-items: center; gap: 6px; color: var(--admin-primary); font-weight: 600; text-decoration: none; font-size: 14px;">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver al listado
          </a>
        </div>

        <!-- Form Card -->
        <div class="form-card">
          <!-- Error Alert -->
          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <form class="admin-form"
                action="<%= especialidad && especialidad.id_especialidad
                    ? '/admin/especialidades/' + especialidad.id_especialidad + '/editar'
                    : '/admin/especialidades/nueva' %>"
                method="POST">

            <div class="form-group">
              <label for="nombre">Nombre de la Especialidad</label>
              <input type="text" id="nombre" name="nombre" class="form-control" placeholder="Ej. Cardiología, Pediatría..." required
                     value="<%= especialidad ? especialidad.nombre : '' %>">
            </div>

            <div class="form-group">
              <label for="duracion_cita_minutos">Duración estimada de cita (minutos)</label>
              <input type="number" id="duracion_cita_minutos" name="duracion_cita_minutos" class="form-control"
                     min="5" max="240" required
                     value="<%= especialidad ? especialidad.duracion_cita_minutos : 30 %>">
              <small style="color: var(--admin-muted); font-size: 11px;">Defina el intervalo estándar reservado para cada cita de esta especialidad (ej. 30, 45 o 60 minutos).</small>
            </div>

            <div class="form-actions">
              <a href="/admin/especialidades" class="btn btn-secondary">Cancelar</a>
              <button type="submit" class="btn btn-primary">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 4px;">
                  <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                  <polyline points="17 21 17 13 7 13 7 21"/>
                  <polyline points="7 3 7 8 15 8"/>
                </svg>
                Guardar Especialidad
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
