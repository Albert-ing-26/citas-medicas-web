<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Administrador</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-container">
    <!-- Sidebar Navigation -->
    <%- include('../partials/admin-sidebar', { activePage: 'inicio' }) %>

    <div class="admin-main">
      <!-- Top Header -->
      <%- include('../partials/admin-header', { title: 'Panel de Control' }) %>

      <div class="admin-content">
        <!-- Hero Section -->
        <section class="glass-card" style="margin-bottom: 32px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
          <div>
            <div style="font-size: 13px; font-weight: 600; text-transform: uppercase; color: var(--admin-primary); letter-spacing: 0.05em; margin-bottom: 8px;">Panel de administración</div>
            <h2 style="font-family: var(--font-display); font-size: 24px; font-weight: 700; margin: 0 0 10px 0;">Supervisa la clínica con una vista completa</h2>
            <p style="color: var(--admin-muted); font-size: 14px; margin: 0; max-width: 700px;">Gestiona especialidades, médicos, pacientes y solicitudes de bloqueo desde un tablero claro y visual en tiempo real.</p>
          </div>
          <div style="background: var(--admin-primary-light); color: var(--admin-primary-dark); font-weight: 600; font-size: 12px; padding: 8px 16px; border-radius: 99px; border: 1px solid rgba(13, 115, 119, 0.1);">
            Operación activa
          </div>
        </section>

        <!-- Stats Grid -->
        <div class="admin-stats-grid">
          <!-- Specialties -->
          <div class="stat-card">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </div>
            <div class="stat-details">
              <div class="stat-number"><%= totalEspecialidades %></div>
              <div class="stat-label">Especialidades</div>
            </div>
          </div>

          <!-- Active Doctors -->
          <div class="stat-card">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <div class="stat-details">
              <div class="stat-number"><%= totalMedicos %></div>
              <div class="stat-label">Médicos Activos</div>
            </div>
          </div>

          <!-- Active Patients -->
          <div class="stat-card">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
              </svg>
            </div>
            <div class="stat-details">
              <div class="stat-number"><%= totalPacientes %></div>
              <div class="stat-label">Pacientes Activos</div>
            </div>
          </div>

          <!-- Today's Appointments -->
          <div class="stat-card">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <div class="stat-details">
              <div class="stat-number"><%= citasHoy %></div>
              <div class="stat-label">Citas de Hoy</div>
            </div>
          </div>

          <!-- Pending Requests -->
          <div class="stat-card <%= solicitudesPendientes > 0 ? 'accent' : '' %>">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </div>
            <div class="stat-details">
              <div class="stat-number"><%= solicitudesPendientes %></div>
              <div class="stat-label">Solicitudes Pendientes</div>
            </div>
          </div>
        </div>

        <!-- Content Grid (Actions + Chart) -->
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; align-items: start;" class="dashboard-main-grid">
          <div>
            <h3 style="margin-top: 0; margin-bottom: 16px;">Accesos Rápidos</h3>
            
            <div class="admin-actions-grid" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));">
              <!-- Action Specialties -->
              <a href="/admin/especialidades" class="action-card">
                <div class="action-card-icon">
                  <svg viewBox="0 0 24 24">
                    <path d="M12 2l7 4v6c0 5-3.5 8-7 10-3.5-2-7-5-7-10V6l7-4z"/>
                    <path d="M9.5 12l1.8 1.8L14.5 10"/>
                  </svg>
                </div>
                <h4 class="action-card-title">Catálogo Especialidades</h4>
                <p class="action-card-desc">Crea y edita el catálogo de especialidades y configura su duración promedio de cita.</p>
                <div class="action-card-arrow">Gestionar <span>&rarr;</span></div>
              </a>

              <!-- Action Medicos -->
              <a href="/admin/medicos" class="action-card">
                <div class="action-card-icon">
                  <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="8" r="3.2"/>
                    <path d="M5 20c0-4 3-6.5 7-6.5s7 2.5 7 6.5"/>
                  </svg>
                </div>
                <h4 class="action-card-title">Gestión de Médicos</h4>
                <p class="action-card-desc">Registra médicos nuevos, asígnales sus especialidades y administra su información.</p>
                <div class="action-card-arrow">Gestionar <span>&rarr;</span></div>
              </a>

              <!-- Action Pacientes -->
              <a href="/admin/pacientes" class="action-card">
                <div class="action-card-icon">
                  <svg viewBox="0 0 24 24">
                    <circle cx="9" cy="8" r="3"/>
                    <path d="M3 20c0-3.5 2.7-6 6-6s6 2.5 6 6"/>
                    <circle cx="17" cy="7" r="2.2"/>
                  </svg>
                </div>
                <h4 class="action-card-title">Cuentas de Pacientes</h4>
                <p class="action-card-desc">Consulta los pacientes registrados en el sistema, bloquea o elimina accesos.</p>
                <div class="action-card-arrow">Gestionar <span>&rarr;</span></div>
              </a>

              <!-- Action Requests -->
              <a href="/admin/solicitudes-bloqueo" class="action-card <%= solicitudesPendientes > 0 ? 'destacada' : '' %>">
                <div class="action-card-icon">
                  <svg viewBox="0 0 24 24">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                  </svg>
                </div>
                <h4 class="action-card-title">Días de Bloqueo</h4>
                <p class="action-card-desc">
                  <%= solicitudesPendientes > 0
                      ? solicitudesPendientes + ' solicitud(es) esperando tu aprobación.'
                      : 'Revisa y aprueba los días solicitados para bloquear por los médicos.' %>
                </p>
                <div class="action-card-arrow">Revisar <span>&rarr;</span></div>
              </a>

              <!-- Action Reports -->
              <a href="/admin/reportes" class="action-card destacada">
                <div class="action-card-icon">
                  <svg viewBox="0 0 24 24">
                    <path d="M4 20V10M11 20V4M18 20v-7"/>
                    <path d="M3 20h18"/>
                  </svg>
                </div>
                <h4 class="action-card-title">Reportes y Estadísticas</h4>
                <p class="action-card-desc">Visualiza las citas consolidadas por estado, especialidades y el desempeño de los médicos.</p>
                <div class="action-card-arrow">Ver reportes <span>&rarr;</span></div>
              </a>
            </div>
          </div>

          <!-- Chart Area -->
          <div>
            <h3 style="margin-top: 0; margin-bottom: 16px;">Actividad de la Clínica</h3>
            <div class="glass-card" style="padding: 24px;">
              <h4 style="margin: 0 0 8px 0; font-family: var(--font-body); font-size: 15px; font-weight: 600; color: var(--admin-ink);">Resumen Operativo</h4>
              <p style="color: var(--admin-muted); font-size: 12px; margin: 0 0 20px 0; line-height: 1.4;">Vista general en tiempo real de los principales indicadores.</p>
              <div style="position: relative; height: 260px; width: 100%;">
                <canvas id="adminChart"></canvas>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const ctx = document.getElementById('adminChart');
      if (!ctx) return;
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['Especialidades', 'Médicos', 'Pacientes', 'Citas hoy'],
          datasets: [{
            label: 'Resumen general',
            data: [<%= totalEspecialidades %>, <%= totalMedicos %>, <%= totalPacientes %>, <%= citasHoy %>],
            backgroundColor: ['#0F766E', '#14B8A6', '#F97362', '#FBBF24'],
            borderRadius: 8,
            borderWidth: 0,
            barThickness: 24
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { 
            legend: { display: false },
            tooltip: {
              backgroundColor: '#16242a',
              titleFont: { family: 'Inter', size: 12, weight: 'bold' },
              bodyFont: { family: 'Inter', size: 12 },
              padding: 10,
              cornerRadius: 6
            }
          },
          scales: { 
            y: { 
              beginAtZero: true,
              grid: {
                color: '#e1eeec',
                drawBorder: false
              },
              ticks: {
                font: { family: 'Inter', size: 11 }
              }
            },
            x: {
              grid: { display: false },
              ticks: {
                font: { family: 'Inter', size: 11, weight: '500' }
              }
            }
          }
        }
      });
    });
  </script>
</body>
</html>

