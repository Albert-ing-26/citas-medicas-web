<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Paciente - Panel Administrador</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-container">
    <!-- Sidebar Navigation -->
    <%- include('../../partials/admin-sidebar', { activePage: 'pacientes' }) %>

    <div class="admin-main">
      <!-- Top Header -->
      <%- include('../../partials/admin-header', { title: 'Editar Paciente' }) %>

      <div class="admin-content">
        <!-- Back Link -->
        <div style="margin-bottom: 24px;">
          <a href="/admin/pacientes" style="display: inline-flex; align-items: center; gap: 6px; color: var(--admin-primary); font-weight: 600; text-decoration: none; font-size: 14px;">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver al listado
          </a>
        </div>

        <!-- Form Card -->
        <div class="form-card">
          <!-- Error Alert -->
          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <form class="admin-form" action="/admin/pacientes/<%= paciente.id_paciente %>/editar" method="POST">

            <!-- ALERTA DE DATOS DE IDENTIDAD BLOQUEADOS -->
            <div style="background: rgba(13, 115, 119, 0.05); border: 1px solid var(--admin-border); padding: 16px; border-radius: var(--admin-radius-sm); margin-bottom: 24px;">
              <h4 style="margin: 0 0 6px 0; color: var(--admin-primary); font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 6px;">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--admin-primary);">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="12" y1="16" x2="12" y2="12"/>
                  <line x1="12" y1="8" x2="12.01" y2="8"/>
                </svg>
                Políticas de Seguridad e Identidad Legal
              </h4>
              <p style="margin: 0; font-size: 13px; color: var(--admin-muted); line-height: 1.4;">
                Los campos de identificación (Nombres, Apellidos, DNI y Correo) son de solo lectura. Esto previene la desvinculación accidental de historias clínicas o el bloqueo imprevisto del login del paciente.
              </p>
            </div>

            <!-- Datos Personales (Read Only) -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <div class="form-group">
                <label for="nombre">Nombre (Solo Lectura)</label>
                <input type="text" id="nombre" class="form-control" readonly style="background-color: var(--admin-bg); color: var(--admin-muted); cursor: not-allowed;"
                       value="<%= paciente.nombre %>">
              </div>

              <div class="form-group">
                <label for="apellidos">Apellidos (Solo Lectura)</label>
                <input type="text" id="apellidos" class="form-control" readonly style="background-color: var(--admin-bg); color: var(--admin-muted); cursor: not-allowed;"
                       value="<%= paciente.apellidos %>">
              </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <div class="form-group">
                <label for="dni">DNI / Documento (Solo Lectura)</label>
                <input type="text" id="dni" class="form-control" readonly style="background-color: var(--admin-bg); color: var(--admin-muted); cursor: not-allowed; font-family: var(--font-mono);"
                       value="<%= paciente.dni %>">
              </div>

              <div class="form-group">
                <label for="correo">Correo Electrónico (Solo Lectura)</label>
                <input type="email" id="correo" class="form-control" readonly style="background-color: var(--admin-bg); color: var(--admin-muted); cursor: not-allowed;"
                       value="<%= paciente.correo %>">
              </div>
            </div>

            <!-- Datos Modificables (Editable) -->
            <div class="form-group">
              <label for="telefono">Teléfono de Contacto (Editable)</label>
              <input type="text" id="telefono" name="telefono" class="form-control" placeholder="Ej. 987654321" required
                     value="<%= paciente.telefono || '' %>">
            </div>

            <div class="form-group">
              <label for="direccion">Dirección Domiciliaria (Editable)</label>
              <input type="text" id="direccion" name="direccion" class="form-control" placeholder="Ej. Av. Grau 123, Piura"
                     value="<%= paciente.direccion || '' %>">
            </div>

            <div class="form-actions" style="margin-top: 32px;">
              <a href="/admin/pacientes" class="btn btn-secondary">Cancelar</a>
              <button type="submit" class="btn btn-primary">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 4px;">
                  <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                  <polyline points="17 21 17 13 7 13 7 21"/>
                  <polyline points="7 3 7 8 15 8"/>
                </svg>
                Guardar Cambios
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
