<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= medico && medico.id_medico ? 'Editar' : 'Nuevo' %> Médico - Panel Administrador</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-container">
    <!-- Sidebar Navigation -->
    <%- include('../../partials/admin-sidebar', { activePage: 'medicos' }) %>

    <div class="admin-main">
      <!-- Top Header -->
      <%- include('../../partials/admin-header', { title: medico && medico.id_medico ? 'Editar Médico' : 'Nuevo Médico' }) %>

      <div class="admin-content">
        <!-- Back Link -->
        <div style="margin-bottom: 24px;">
          <a href="/admin/medicos" style="display: inline-flex; align-items: center; gap: 6px; color: var(--admin-primary); font-weight: 600; text-decoration: none; font-size: 14px;">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver al listado
          </a>
        </div>

        <!-- Form Card -->
        <div class="form-card">
          <!-- Error Alert -->
          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <form class="admin-form"
                action="<%= medico && medico.id_medico
                    ? '/admin/medicos/' + medico.id_medico + '/editar'
                    : '/admin/medicos/nuevo' %>"
                method="POST">

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <div class="form-group">
                <label for="nombre">Nombre</label>
                <input type="text" id="nombre" name="nombre" class="form-control" placeholder="Ej. Juan" required
                       pattern="^[A-Za-záéíóúÁÉÍÓÚñÑ\s]+$" title="Solo se permiten letras y espacios"
                       value="<%= medico ? medico.nombre : '' %>">
              </div>

              <div class="form-group">
                <label for="apellidos">Apellidos</label>
                <input type="text" id="apellidos" name="apellidos" class="form-control" placeholder="Ej. Pérez..." required
                       pattern="^[A-Za-záéíóúÁÉÍÓÚñÑ\s]+$" title="Solo se permiten letras y espacios"
                       value="<%= medico ? medico.apellidos : '' %>">
              </div>
            </div>

            <div class="form-group">
              <label for="correo">Correo Electrónico</label>
              <input type="email" id="correo" name="correo" class="form-control" placeholder="juan.perez@clinica.com" required
                     value="<%= medico ? medico.correo : '' %>">
            </div>

            <div class="form-group">
              <label for="telefono">Teléfono de Contacto</label>
              <input type="text" id="telefono" name="telefono" class="form-control" placeholder="Ej. 987654321"
                     value="<%= medico ? medico.telefono : '' %>">
            </div>

            <div class="form-group">
              <label for="id_especialidad">Especialidad Asignada</label>
              <select id="id_especialidad" name="id_especialidad" class="form-control" required style="height: auto;">
                <option value="" disabled <%= !medico ? 'selected' : '' %>>Seleccione una especialidad...</option>
                <% especialidades.forEach(e => { %>
                  <option value="<%= e.id_especialidad %>"
                    <%= medico && medico.id_especialidad == e.id_especialidad ? 'selected' : '' %>>
                    <%= e.nombre %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group">
              <label for="colegiatura">Número de Colegiatura (CMP)</label>
              <input type="text" id="colegiatura" name="colegiatura" class="form-control" placeholder="CMP-XXXXXX" required
                     pattern="^[a-zA-Z0-9-]{3,15}$" title="Ejemplo: CMP-45210"
                     value="<%= medico ? medico.colegiatura : '' %>"
                     <%= medico && medico.id_medico ? 'readonly style="background-color: var(--admin-bg); color: var(--admin-muted); cursor: not-allowed;"' : '' %>>
              <% if (medico && medico.id_medico) { %>
                <small style="color: var(--admin-accent); display: block; margin-top: 4px; font-weight: 500;">
                  ⚠️ La colegiatura no puede modificarse después del registro por motivos de seguridad.
                </small>
              <% } %>
            </div>

            <% if (!medico || !medico.id_medico) { %>
              <div class="form-group">
                <label for="password">Contraseña de Acceso</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Ingrese contraseña" required>
              </div>
            <% } %>

            <div class="form-actions">
              <a href="/admin/medicos" class="btn btn-secondary">Cancelar</a>
              <button type="submit" class="btn btn-primary">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 4px;">
                  <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                  <polyline points="17 21 17 13 7 13 7 21"/>
                  <polyline points="7 3 7 8 15 8"/>
                </svg>
                Guardar Médico
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
