<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Médicos - Panel Administrador</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-container">
    <!-- Sidebar Navigation -->
    <%- include('../../partials/admin-sidebar', { activePage: 'medicos' }) %>

    <div class="admin-main">
      <!-- Top Header -->
      <%- include('../../partials/admin-header', { title: 'Gestión de Médicos' }) %>

      <div class="admin-content">
        <!-- Error Alert -->
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
          <p style="color: var(--admin-muted); font-size: 14px; margin: 0;">Registra nuevos profesionales de la salud, edita sus datos de contacto y especialidad, o suspende (bloquear/reactivar) su acceso al sistema.</p>
          <a class="btn btn-primary" href="/admin/medicos/nuevo">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 4px;">
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nuevo Médico
          </a>
        </div>

        <!-- Doctors Table -->
        <div class="table-container">
          <div class="table-header-bar">
            <h3>Médicos Registrados</h3>
            <span style="font-size: 12px; color: var(--admin-muted); font-weight: 500;"><%= medicos.length %> médicos en base de datos</span>
          </div>

          <table class="admin-table">
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Especialidad</th>
                <th>Colegiatura (CMP)</th>
                <th>Correo</th>
                <th>Teléfono</th>
                <th>Estado</th>
                <th style="text-align: right;">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% medicos.forEach(m => { %>
                <tr>
                  <td>
                    <div style="display: flex; align-items: center; gap: 10px;">
                      <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--admin-primary-light); color: var(--admin-primary); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 12px;">
                        <%= m.nombre.charAt(0).toUpperCase() %>
                      </div>
                      <div>
                        <div style="font-weight: 600;"><%= m.nombre %> <%= m.apellidos %></div>
                        <div style="font-size: 11px; color: var(--admin-muted);">Dr(a).</div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span style="background: var(--admin-primary-light); color: var(--admin-primary-dark); font-weight: 600; font-size: 12px; padding: 4px 10px; border-radius: 6px;">
                      <%= m.especialidad %>
                    </span>
                  </td>
                  <td style="font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--admin-muted);"><%= m.colegiatura %></td>
                  <td><%= m.correo %></td>
                  <td><%= m.telefono || '-' %></td>
                  <td>
                    <span class="status-badge <%= m.activo ? 'activo' : 'bloqueado' %>">
                      <%= m.activo ? 'activo' : 'bloqueado' %>
                    </span>
                  </td>
                  <td style="text-align: right;">
                    <a href="/admin/medicos/<%= m.id_medico %>/editar" class="table-action-btn">
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 2px;">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                      </svg>
                      Editar
                    </a>
                    
                    <!-- Block/Unblock Form Button -->
                    <form action="/admin/medicos/<%= m.id_medico %>/bloquear" method="POST" style="display:inline">
                      <button type="submit" class="table-action-btn">
                        <% if (m.activo) { %>
                          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 2px;">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                          </svg>
                          Bloquear
                        <% } else { %>
                          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 2px;">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
                          </svg>
                          Reactivar
                        <% } %>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
              <% if (medicos.length === 0) { %>
                <tr>
                  <td colspan="6" style="text-align: center; color: var(--admin-muted); padding: 30px;">
                    No hay médicos registrados todavía.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
