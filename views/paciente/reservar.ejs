<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Reservar cita</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="paciente-header">
    <h1>Reservar Cita</h1>
    <nav class="paciente-nav">
      <a href="/paciente" class="paciente-nav-link">
        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
        Inicio
      </a>
      <a href="/paciente/reservar" class="paciente-nav-link active">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line><line x1="12" y1="15" x2="12" y2="19"></line><line x1="10" y1="17" x2="14" y2="17"></line></svg>
        Reservar
      </a>
      <a href="/paciente/mis-citas" class="paciente-nav-link">
        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        Citas
      </a>
      <%- include('../partials/perfil-widget') %>
    </nav>
  </header>

  <div class="contenido">
    <h2>Reservar una cita</h2>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <div class="reserva-shell">
      <div class="reserva-panel">
        <div class="reserva-step">Paso 1 · Selección</div>
        <form class="formulario reserva-panel-form" method="GET" action="/paciente/reservar">
          <label for="id_especialidad">Especialidad</label>
          <select id="id_especialidad" name="id_especialidad" required onchange="this.form.submit()">
            <option value="">-- Selecciona --</option>
            <% especialidades.forEach(e => { %>
              <option value="<%= e.id_especialidad %>"
                <%= String(seleccion.id_especialidad) === String(e.id_especialidad) ? 'selected' : '' %>>
                <%= e.nombre %>
              </option>
            <% }) %>
          </select>

          <% if (seleccion.id_especialidad) { %>
            <label for="id_medico">Médico</label>
            <select id="id_medico" name="id_medico" required onchange="this.form.submit()">
              <option value="">-- Selecciona --</option>
              <% medicos.forEach(m => { %>
                <option value="<%= m.id_medico %>"
                  <%= String(seleccion.id_medico) === String(m.id_medico) ? 'selected' : '' %>>
                  <%= m.nombre %> <%= m.apellidos %>
                </option>
              <% }) %>
            </select>
            <% if (medicos.length === 0) { %>
              <p class="nota">No hay médicos activos registrados en esta especialidad todavía.</p>
            <% } %>
          <% } %>

          <% if (seleccion.id_especialidad && seleccion.id_medico) { %>
            <label for="fecha">Fecha</label>
            <input type="date" id="fecha" name="fecha" required min="<%= minFecha %>" max="<%= maxFecha %>"
                   value="<%= seleccion.fecha || '' %>" onchange="this.form.submit()">
          <% } %>
        </form>

        <% if (mensajeSlots) { %>
          <p class="nota"><%= mensajeSlots %></p>
        <% } %>

        <% if (slots.length > 0) { %>
          <div class="reserva-step">Paso 2 · Confirmación</div>
          <form class="formulario reserva-panel-form" method="POST" action="/paciente/reservar">
            <input type="hidden" name="id_especialidad" value="<%= seleccion.id_especialidad %>">
            <input type="hidden" name="id_medico" value="<%= seleccion.id_medico %>">
            <input type="hidden" name="fecha" value="<%= seleccion.fecha %>">

            <label>Horario Disponible</label>
            <div class="slots-grid">
              <% slots.forEach(s => { %>
                <label>
                  <input type="radio" name="hora_inicio" value="<%= s %>" required class="slot-input">
                  <span class="slot-block"><%= s.substring(0,5) %></span>
                </label>
              <% }) %>
            </div>

            <label for="motivo_consulta">Motivo de la consulta</label>
            <input type="text" id="motivo_consulta" name="motivo_consulta" required
                   placeholder="Ej: dolor de cabeza persistente">

            <button type="submit">Confirmar reserva</button>
          </form>
        <% } %>
      </div>

      <aside class="reserva-panel reserva-summary">
        <div class="reserva-badge">Agenda en minutos</div>
        <h3>Tu próxima cita se arma aquí</h3>
        <div class="reserva-summary-list">
          <div class="reserva-summary-item">
            <span>Especialidad</span>
            <strong><%= seleccion.id_especialidad ? (especialidades.find(e => String(e.id_especialidad) === String(seleccion.id_especialidad))?.nombre || 'Por elegir') : 'Por elegir' %></strong>
          </div>
          <div class="reserva-summary-item">
            <span>Médico</span>
            <strong><%= seleccion.id_medico ? (medicos.find(m => String(m.id_medico) === String(seleccion.id_medico)) ? medicos.find(m => String(m.id_medico) === String(seleccion.id_medico)).nombre + ' ' + medicos.find(m => String(m.id_medico) === String(seleccion.id_medico)).apellidos : 'Por elegir') : 'Por elegir' %></strong>
          </div>
          <div class="reserva-summary-item">
            <span>Fecha</span>
            <strong><%= seleccion.fecha || 'Por elegir' %></strong>
          </div>
        </div>
        <div class="reserva-illustration">
          <div class="icono">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 3l8 4v5c0 5.2-3.4 8.8-8 10-4.6-1.2-8-4.8-8-10V7l8-4z"/>
              <path d="M9.5 12l1.8 1.8 3.2-3.3"/>
            </svg>
          </div>
          <p>Selecciona tus datos para recibir horarios disponibles en segundos y reservar con total confianza.</p>
        </div>
      </aside>
    </div>
  </div>
</body>
</html>
