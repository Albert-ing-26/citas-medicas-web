<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Panel Paciente</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <h1>Bienvenido, <%= usuario.nombre %></h1>
  <nav>
    <a href="/paciente">Inicio</a> |
    <a href="/paciente/reservar">Reservar cita</a> |
    <a href="/paciente/mis-citas">Mis citas</a>
  </nav>
  <%- include('../partials/perfil-widget') %>
  <div class="contenido">
    <div class="dashboard-shell">
      <section class="dashboard-hero">
        <div>
          <div class="eyebrow">Panel del paciente</div>
          <h2 style="margin-bottom: 8px;">Gestiona tu salud con una vista más clara</h2>
          <p class="saludo-intro" style="margin-bottom: 0;">Desde aquí puedes reservar una nueva cita con el médico que necesites o revisar el estado de tus consultas.</p>
        </div>
        <div class="dashboard-pill">Tu bienestar, en orden</div>
      </section>

      <div class="dashboard-grid">
        <div>
          <div class="tarjetas-resumen">
            <div class="tarjeta">
              <div class="numero"><%= proximasCitas %></div>
              <div class="etiqueta">Citas próximas</div>
            </div>
            <div class="tarjeta">
              <div class="numero"><%= citasAtendidas %></div>
              <div class="etiqueta">Citas atendidas</div>
            </div>
          </div>

          <div class="grid-acciones">
            <a href="/paciente/reservar" class="tarjeta-accion destacada">
              <div class="icono">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <rect x="3" y="5" width="18" height="16" rx="2"/>
                  <path d="M3 9h18M8 3v4M16 3v4M12 13v5M9.5 15.5h5"/>
                </svg>
              </div>
              <div class="titulo">Reservar una cita</div>
              <div class="descripcion">Elige especialidad, médico, fecha y horario disponible en unos segundos.</div>
              <div class="flecha">Reservar &rarr;</div>
            </a>

            <a href="/paciente/mis-citas" class="tarjeta-accion">
              <div class="icono">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 3v4M16 3v4M4 9h16M6 5h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2z"/>
                  <path d="M8 13h3M8 17h6"/>
                </svg>
              </div>
              <div class="titulo">Ver mis citas</div>
              <div class="descripcion">Revisa el estado de tus citas reservadas y cancela si ya no las necesitas.</div>
              <div class="flecha">Ver citas &rarr;</div>
            </a>
          </div>
        </div>

        <div class="dashboard-chart">
          <h3>Resumen rápido</h3>
          <p>Tu actividad se organiza en una sola vista para que tomes decisiones más rápido.</p>
          <canvas id="pacienteChart" width="300" height="220"></canvas>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const ctx = document.getElementById('pacienteChart');
      if (!ctx) return;
      new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: ['Próximas', 'Atendidas'],
          datasets: [{
            data: [<%= proximasCitas %>, <%= citasAtendidas %>],
            backgroundColor: ['#0d7377', '#ff6f59'],
            borderColor: '#ffffff',
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: 'bottom' } }
        }
      });
    });
  </script>
</body>
</html>
