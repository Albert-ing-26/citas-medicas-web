<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Mis citas</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="paciente-header">
    <h1>Mis Citas</h1>
    <nav class="paciente-nav">
      <a href="/paciente" class="paciente-nav-link">
        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
        Inicio
      </a>
      <a href="/paciente/reservar" class="paciente-nav-link">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line><line x1="12" y1="15" x2="12" y2="19"></line><line x1="10" y1="17" x2="14" y2="17"></line></svg>
        Reservar
      </a>
      <a href="/paciente/mis-citas" class="paciente-nav-link active">
        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        Citas
      </a>
      <%- include('../partials/perfil-widget') %>
    </nav>
  </header>

  <div class="contenido">
    <h2>Mis citas</h2>

    <% if (mensaje) { %>
      <p class="nota"><%= mensaje %></p>
    <% } %>

    <% if (citas.length > 0) { %>
    <table class="tabla">
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Hora</th>
          <th>Medico</th>
          <th>Especialidad</th>
          <th>Motivo</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% citas.forEach(c => { %>
          <tr>
            <td><%= c.fecha.toISOString ? c.fecha.toISOString().substring(0,10) : c.fecha %></td>
            <td><%= c.hora_inicio.substring(0,5) %> - <%= c.hora_fin.substring(0,5) %></td>
            <td>Dr(a). <%= c.medico_nombre %> <%= c.medico_apellidos %></td>
            <td><%= c.especialidad %></td>
            <td><%= c.motivo_consulta %></td>
            <td>
              <span class="estado-<%= c.estado === 'cancelada' ? 'bloqueado' : 'activo' %>">
                <%= c.estado %>
              </span>
            </td>
            <td>
              <% if (c.estado === 'pendiente' || c.estado === 'confirmada') { %>
                <form action="/paciente/mis-citas/<%= c.id_cita %>/cancelar" method="POST"
                      style="display:inline"
                      onsubmit="return confirm('Seguro que deseas cancelar esta cita?');">
                  <button type="submit" class="link-eliminar">Cancelar</button>
                </form>
              <% } else { %>
                -
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <% } else { %>
      <div class="empty-state">
        <svg viewBox="0 0 24 24"><path d="M19 4h-3V2h-2v2h-4V2H8v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10z"></path></svg>
        <p>Todavía no tienes citas reservadas.</p>
        <a href="/paciente/reservar" class="boton">Reservar mi primera cita</a>
      </div>
    <% } %>
  </div>
</body>
</html>
